# Inforact backend
INFORACT_API_URL=http://192.168.65.254:9090
INFORACT_APP_TOKEN=<your-app-token-here>

# Skip startup admin init in dev (safe default)
NEXT_PUBLIC_SKIP_INIT=true

# Dev-only JWT fallback. In production, JWT is read from localStorage.access_token
# (set by the login flow). For local dev without a real login, paste a JWT here —
# it will be used by lib/inforact-sdk.ts and lib/inforact-sdk-ext.ts when no token
# is in localStorage.
#
# Example (pham.thi.g — LEADER of grp_ke_toan):
# NEXT_PUBLIC_DEV_JWT=eyJzd191c2VyX2lkIjoxNjcyMyw...
NEXT_PUBLIC_DEV_JWT=
